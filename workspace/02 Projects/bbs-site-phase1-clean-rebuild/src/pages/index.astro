---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import CaseStudySection from '../components/CaseStudySection.astro';
import CTASection from '../components/CTASection.astro';
import Card from '../components/Card.astro';
import Grid from '../components/Grid.astro';
import { homePage } from '../data/home';
import { siteMeta } from '../data/site';
---

<MainLayout title={homePage.seo.title} description={homePage.seo.description}>
  <Section size="wide">
    <Hero
      eyebrow={homePage.hero.eyebrow}
      headline={homePage.hero.headline}
      subheadline={homePage.hero.subheadline}
      intro={homePage.hero.intro}
      primaryLabel={siteMeta.primaryCtaLabel}
      primaryHref={siteMeta.bookingHref}
      secondaryLabel={siteMeta.secondaryCtaLabel}
      secondaryHref={siteMeta.processHref}
      highlights={homePage.hero.highlights}
      statsHeading={homePage.hero.statsHeading}
      stats={homePage.hero.stats}
    />
  </Section>

  <ProblemSection
    eyebrow={homePage.problemFrames.eyebrow}
    title={homePage.problemFrames.title}
    items={homePage.problemFrames.items}
    closing={homePage.problemFrames.closing}
  />

  <ServicesSection
    eyebrow={homePage.whatWeBuild.eyebrow}
    title={homePage.whatWeBuild.title}
    intro={homePage.whatWeBuild.intro}
    items={homePage.whatWeBuild.items}
  />

  <ProcessSection
    eyebrow={homePage.process.eyebrow}
    title={homePage.process.title}
    steps={homePage.process.steps}
  />

  <CaseStudySection
    eyebrow={homePage.reviewCovers.eyebrow}
    title={homePage.reviewCovers.title}
    intro={homePage.reviewCovers.intro}
    items={homePage.reviewCovers.items}
    closing={homePage.reviewCovers.closing}
  />

  <Section size="standard">
    <div class="section-layout">
      <div class="section-header">
        <p class="eyebrow">{homePage.metrics.eyebrow}</p>
        <h2>{homePage.metrics.title}</h2>
        <p class="text-muted metric-card-note">{homePage.metrics.note}</p>
      </div>
      <div class="metrics-band">
        {homePage.metrics.items.map((item) => (
          <div class="metric-item">
            <span class="metric-value">{item.label}</span>
            <span class="metric-label">{item.body}</span>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section>
    <div class="section-layout">
      <div class="section-header">
        <p class="eyebrow">{homePage.outcomes.eyebrow}</p>
        <h2>{homePage.outcomes.title}</h2>
      </div>
      <Grid columns={3}>
        {homePage.outcomes.items.map((item) => (
          <Card>
            <div class="content-stack">
              <h3>{item.title}</h3>
              <p class="text-muted">{item.body}</p>
            </div>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <Section>
    <div class="section-layout split-block">
      <div class="section-header">
        <p class="eyebrow">{homePage.fitClarity.eyebrow}</p>
        <h2>{homePage.fitClarity.title}</h2>
      </div>
      <div class="split-list">
        <Card>
          <div class="content-stack">
            <h3>{homePage.fitClarity.forHeading}</h3>
            <ul class="bullet-list list-clean">
              {homePage.fitClarity.forItems.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </Card>
        <Card>
          <div class="content-stack">
            <h3>{homePage.fitClarity.notHeading}</h3>
            <ul class="bullet-list list-clean">
              {homePage.fitClarity.notItems.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </Card>
      </div>
    </div>
  </Section>

  <CTASection
    eyebrow={homePage.cta.eyebrow}
    title={homePage.cta.title}
    body={homePage.cta.body}
    buttonLabel={siteMeta.primaryCtaLabel}
    buttonHref={siteMeta.bookingHref}
  />
</MainLayout>

<style>
  .section-layout,
  .content-stack {
    display: grid;
    gap: var(--space-5);
  }

  .content-stack {
    gap: var(--space-3);
  }
</style>
