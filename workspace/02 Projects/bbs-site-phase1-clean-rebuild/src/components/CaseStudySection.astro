---
import Section from './Section.astro';
import Card from './Card.astro';
import Grid from './Grid.astro';

export interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
  items: { title: string; body: string }[];
  closing?: string;
}

const { eyebrow, title, intro, items, closing } = Astro.props;
---

<Section>
  <div class="section-wrap">
    <div class="section-header">
      <p class="eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
      {intro && <p class="text-muted">{intro}</p>}
    </div>

    <Grid columns={2}>
      {items.map((item) => (
        <Card>
          <div class="content-stack">
            <h3>{item.title}</h3>
            <p class="text-muted">{item.body}</p>
          </div>
        </Card>
      ))}
    </Grid>

    {closing && <p class="text-muted section-closing">{closing}</p>}
  </div>
</Section>

<style>
  .section-wrap,
  .content-stack {
    display: grid;
    gap: var(--space-5);
  }

  .content-stack {
    gap: var(--space-3);
  }

  .section-closing {
    max-width: 760px;
  }
</style>
