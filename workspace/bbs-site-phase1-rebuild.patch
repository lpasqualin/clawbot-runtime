+.note { padding: 1rem 1.15rem; border-radius: var(--radius-sm); border: 1px dashed rgba(140,231,155,.26); background: rgba(140,231,155,.05); }
+.code-inline { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: .88rem; color: var(--accent); }
+.booking-placeholder { min-height: 100%; justify-content: center; }
+@media (max-width: 1100px) { .process-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
+@media (max-width: 900px) { .grid-2, .grid-3, .hero-grid, .cta-strip, .process-grid, .hero-proof { grid-template-columns: 1fr; } .section-shell { padding: 5rem 0; } .section-shell--hero { padding-top: 5.5rem; } .hero-title, .hero-title--compact { max-width: none; } .hero-sidecard { min-height: unset; } .sidecard-body { justify-content: flex-start; } .cta-actions { justify-content: flex-start; } .nav-wrap { align-items: flex-start; flex-direction: column; gap: .85rem; } .emphasis-block { padding: 1.3rem 1.5rem; } .cta-strip { padding: 1.75rem; } }
