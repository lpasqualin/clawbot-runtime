+.site-header { position: sticky; top: 0; z-index: 30; background: rgba(6,16,24,.8); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); border-bottom: 1px solid rgba(104,127,149,.12); }
+.nav-wrap { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; padding: 1rem 0; }
+.brand { display: inline-flex; flex-direction: column; gap: .22rem; min-width: 0; flex-shrink: 0; }
+.brand strong { font-size: .96rem; letter-spacing: .1em; text-transform: uppercase; color: var(--text); font-weight: 700; }
+.brand span { color: var(--muted); font-size: .76rem; letter-spacing: .025em; line-height: 1.3; }
+.nav-links { display: flex; gap: 1.1rem; flex-wrap: wrap; align-items: center; }
+.nav-links a { color: var(--muted); font-size: .92rem; transition: color 120ms ease; }
+.nav-links a:hover, .nav-links a[aria-current='page'] { color: var(--text); }
+.nav-cta { margin-left: .35rem; }
+.site-footer { padding: 2.5rem 0 0; background: rgba(4,11,18,.96); border-top: 1px solid rgba(104,127,149,.1); }
+.footer-grid { display: flex; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
+.footer-brand, .footer-links { max-width: 30rem; }
+.footer-brand strong { font-size: .95rem; font-weight: 700; color: var(--text); }
+.footer-grid p { font-size: .93rem; line-height: 1.6; margin-top: .4rem; }
+.footer-links strong { font-size: .82rem; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); font-weight: 600; }
+.footer-links .nav-links { margin-top: .65rem; display: flex; flex-direction: column; gap: .45rem; }
+.footer-links .nav-links a { font-size: .9rem; color: var(--muted); }
+.footer-links .nav-links a:hover { color: var(--text); }
+.footer-legal { margin-top: 2rem; padding: 1.25rem 0 2.5rem; border-top: 1px solid rgba(104,127,149,.08); }
+.footer-legal p { font-size: .8rem; color: var(--muted); opacity: .72; }
+.form-card h2 { font-size: 1.4rem; }
+.form-shell { display: grid; gap: 1rem; }
+.field { display: grid; gap: .45rem; }
+.field label { color: var(--text); font-size: .91rem; font-weight: 500; }
+.field input, .field textarea, .field select { width: 100%; border: 1px solid rgba(104,127,149,.18); border-radius: var(--radius-sm); background: rgba(7,17,27,.78); color: var(--text); padding: .9rem 1rem; font-size: .96rem; transition: border-color 120ms ease, background-color 120ms ease; }
+.field input:hover, .field textarea:hover, .field select:hover { border-color: rgba(104,127,149,.32); background: rgba(7,17,27,.92); }
+.field textarea { min-height: 8.5rem; resize: vertical; }
